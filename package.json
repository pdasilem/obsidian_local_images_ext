{
  "name": "obsidian_local_images_ext",
  "version": "0.17.4",
  "type": "module",
  "description": "This is a plugin for Obsidian (https://obsidian.md) that downloads media files from external links and save in local vault.",
  "main": "build/main.js",
  "scripts": {
    "dev": "rollup --config rollup.config.js -w",
    "build": "rollup --config rollup.config.js --environment BUILD:production",
    "version": "json -I -f manifest.json -e \"this.version='$npm_package_version'\" && json -I -f versions.json -e \"this['$npm_package_version']='$(cat manifest.json | json minAppVersion)'\" && git add ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/async-lock": "^1.3.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/safe-regex": "^1.1.2",
    "json": "^11.0.0",
    "obsidian": "^1.12.3",
    "prettier": "^3.8.1",
    "rollup": "^4.59.1",
    "ts-node": "^10.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "async-lock": "^1.4.0",
    "crypto-js": "^4.1.1",
    "file-type": "^21.3.3",
    "is-svg": "^6.1.0",
    "moment": "^2.30.1",
    "rollup-plugin-execute": "^1.1.1",
    "safe-regex": "^2.1.1"
  },
  "optionalDependencies": {
    "fsevents": "*"
  }
}
